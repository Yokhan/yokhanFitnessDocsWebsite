# IMPORTANT: Copy this file to .env and fill in real values.
# NEVER commit .env to git. All CHANGE_ME_BEFORE_USE values MUST be replaced.

# === Project ===
# NODE_ENV=development
# PORT=3000

# === Database ===
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# === API Keys ===
# API_KEY=CHANGE_ME_BEFORE_USE

# === Telegram Bot (optional, see integrations/telegram/) ===
# TELEGRAM_BOT_TOKEN=CHANGE_ME_BEFORE_USE
# TELEGRAM_CHAT_ID=CHANGE_ME_BEFORE_USE

# === Memory MCP (optional, see integrations/memory-mcp/) ===
# MEMORY_DB_PATH=~/.memory-mcp/memory.db

# === Beads (optional, see integrations/beads/) ===
# BEADS_DB_PATH=.beads/beads.db
