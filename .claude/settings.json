{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.md|*.mdx) ;; *.css|*.js|*.json) npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true ;; esac",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run start)",
      "Bash(npm run serve)",
      "Bash(npm run clear)",
      "Bash(git *)"
    ]
  }
}
